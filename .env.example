# --- OpenAI (embeddings + RAG chat) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# MUST match Pinecone index dimension exactly (check index settings in console).
# Common: 1536 (default 3-small), 1024, 512. text-embedding-3* can request reduced size.
# If you see "Vector dimension X does not match the dimension of the index Y",
# set EMBEDDING_DIMENSIONS=Y and restart the server.
EMBEDDING_DIMENSIONS=1536
# Example for a 1024-dim index:
# EMBEDDING_DIMENSIONS=1024

# --- Pinecone ---
# Create a serverless index: metric cosine, dimension = EMBEDDING_DIMENSIONS
PINECONE_API_KEY=
PINECONE_INDEX_NAME=amazon-reviews
# Optional: only if Pinecone console shows a host URL for your index
# PINECONE_HOST=https://xxxx.pinecone.io

PINECONE_UPSERT_BATCH=100
MAX_METADATA_TEXT_CHARS=32000
RAG_DEFAULT_TOP_K=8

# --- HTTP / legacy demo ---
PORT=3000
# DEBUG_HTTP=1   # log each request (method, path, content-type) — see src/routes/index.js
CHUNK_SIZE=400
CHUNK_OVERLAP=50
